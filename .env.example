VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side secrets (Vercel dashboard + local .env; never VITE_-prefixed).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
GEMINI_API_KEY=your_gemini_api_key

# Market-insight cron (api/generate-market-insight.ts). Any random 32-byte
# string; Vercel Cron auto-sends "Authorization: Bearer $CRON_SECRET".
CRON_SECRET=change_me_to_a_random_string
